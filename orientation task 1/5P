import java.util.LinkedList;

public class ServicePoint {

    private LinkedList<Customer> queue =
            new LinkedList<>();

    public void addToQueue(Customer c) {
        queue.addLast(c);
    }

    public Customer removeFromQueue() {
        return queue.removeFirst();
    }

    public void serve() {

        while (!queue.isEmpty()) {

            Customer c =
                    removeFromQueue();

            long start =
                    System.nanoTime();

            try {
                Thread.sleep(
                        (int)(Math.random()*1000));
            } catch (Exception e) {
            }

            long end =
                    System.nanoTime();

            System.out.println(
                    "Customer "
                    + c.getId());

            System.out.println(
                    "Service time: "
                    + (end - start));
        }
    }
}


public class Main {

    public static void main(String[] args) {

        ServicePoint sp =
                new ServicePoint();

        for (int i = 0; i < 5; i++) {

            Customer c = new Customer();

            c.setStartTime(System.nanoTime());

            sp.addToQueue(c);
        }

        sp.serve();
    }
}


Add these variables to ServicePoint:

private long totalServiceTime = 0;
private int customersServed = 0;

Inside serve():

long serviceTime = end - start;

totalServiceTime += serviceTime;
customersServed++;

Method for average service time:

public double averageServiceTime() {
    return (double) totalServiceTime
            / customersServed;
}

Print result:

System.out.println(
        sp.averageServiceTime());