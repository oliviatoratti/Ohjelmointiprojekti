public enum EventType {
    ARRIVAL,
    EXIT
}


public class Event implements Comparable<Event> {

    private double time;
    private EventType type;

    public Event(double time, EventType type) {
        this.time = time;
        this.type = type;
    }

    public double getTime() {
        return time;
    }

    public EventType getType() {
        return type;
    }

    // Compare events by time
    @Override
    public int compareTo(Event other) {
        return Double.compare(this.time, other.time);
    }

    @Override
    public String toString() {
        return "Time: " + time + ", Type: " + type;
    }
}


import java.util.PriorityQueue;

public class EventList {

    private PriorityQueue<Event> events =
            new PriorityQueue<>();

    // Add event to list
    public void add(Event e) {
        events.add(e);
    }

    // Remove next event
    public Event removeNext() {
        return events.poll();
    }

    // Print events in correct order
    public void printEvents() {

        PriorityQueue<Event> copy =
                new PriorityQueue<>(events);

        while (!copy.isEmpty()) {
            System.out.println(copy.poll());
        }
    }
}


public class Main {

    public static void main(String[] args) {

        EventList list = new EventList();

        // Add events
        list.add(new Event(4.5, EventType.ARRIVAL));
        list.add(new Event(1.2, EventType.EXIT));
        list.add(new Event(3.0, EventType.ARRIVAL));

        // Print all events
        System.out.println("Event List:");
        list.printEvents();

        // Remove next event
        System.out.println("\nNext Event:");
        System.out.println(list.removeNext());
    }
}


