public class Clock {

    private static Clock instance =
            new Clock();

    private double time;

    private Clock() {
        time = 0;
    }

    public static Clock getInstance() {
        return instance;
    }

    public double getTime() {
        return time;
    }

    public void setTime(double time) {
        this.time = time;
    }
}

public class TestClock {

    public static void main(String[] args) {

        Clock c = Clock.getInstance();

        c.setTime(10);

        System.out.println(
                "Clock time: "
                + c.getTime());
    }
}